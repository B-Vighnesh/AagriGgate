            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Demo Market Update\",\n  \"summary\": \"A fresh market advisory for testing the News module.\",\n  \"sourceName\": \"AagriGgate QA\",\n  \"sourceUrl\": \"https://example.com/news/demo-market-update\",\n  \"imageUrl\": \"https://example.com/images/demo-market-update.jpg\",\n  \"category\": \"MARKET\",\n  \"newsType\": \"EXTERNAL\",\n  \"language\": \"en\",\n  \"isImportant\": false\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/admin/news", "host": ["{{base_url}}"], "path": ["api", "v1", "admin", "news"] }
          }
        },
