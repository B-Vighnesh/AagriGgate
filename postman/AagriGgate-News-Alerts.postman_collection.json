{
  "info": {
    "name": "AagriGgate - News",
    "_postman_id": "c8d58d08-4ef2-49f6-98e8-55b69eb77d9c",
    "description": "Postman collection for the hardened News feature with JWT-protected user and admin flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Auth",
      "item": [
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"principal\": \"{{user_principal}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.token) { pm.environment.set('jwt_token', response.token); }",
                  "if (response && response.farmerId) { pm.environment.set('user_id', response.farmerId); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin Auth",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{admin_username}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/admin/login", "host": ["{{base_url}}"], "path": ["api", "v1", "admin", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.data && response.data.token) { pm.environment.set('admin_jwt_token', response.data.token); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "News",
      "item": [
        {
          "name": "Get News Feed",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/news?page=0&size=10&sortBy=newest&dateRange=ALL",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "news"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sortBy", "value": "newest" },
                { "key": "dateRange", "value": "ALL" }
              ]
            }
          }
        },
        {
          "name": "Get Today's Weather News",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/news?category=WEATHER&isImportant=true&dateRange=TODAY&page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "news"],
              "query": [
                { "key": "category", "value": "WEATHER" },
                { "key": "isImportant", "value": "true" },
                { "key": "dateRange", "value": "TODAY" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get News By Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/news/{{news_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "news", "{{news_id}}"] }
          }
        },
        {
          "name": "Track News View",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/news/{{news_id}}/view", "host": ["{{base_url}}"], "path": ["api", "v1", "news", "{{news_id}}", "view"] }
          }
        }
      ]
    },
    {
