          }
        },
        {
          "name": "Check Saved Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/news/saved/{{news_id}}/check", "host": ["{{base_url}}"], "path": ["api", "v1", "news", "saved", "{{news_id}}", "check"] }
          }
        }
      ]
    },
    {
      "name": "Admin News",
      "item": [
